			elseif TDOS_SystemValues.DashboardPositionValue1.Value == 2 then
				Tween6:Play()
			elseif TDOS_SystemValues.DashboardPositionValue1.Value == 3 then
				Tween7:Play()
			elseif TDOS_SystemValues.DashboardPositionValue1.Value == 4 then
