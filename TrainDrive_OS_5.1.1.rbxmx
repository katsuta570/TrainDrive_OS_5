You should have received a copy of the GNU General Public License along with this program. If not, see <https://www.gnu.org/licenses/>.

]]

--Variables

local RemoteEvent = script.Parent.Parent.Parent.TDOS_SystemScripts.RemoteEvent
local SettingButtonsFrame1 = script.Parent.SettingButtonsFrame1
local TDOS_SystemValues = script.Parent.Parent.Parent.TDOS_SystemValues
local TrainDrive_OS = script.Parent.Parent.Parent
local TweenService = game:GetService("TweenService")

--VisibleSettingsMenuValue1 Task

local Tween1_1 = TweenService:Create(script.Parent.Parent.UIScale, TweenInfo.new(0.5, Enum.EasingStyle.Exponential), {Scale = 0.9})
local Tween1_2 = TweenService:Create(script.Parent.Parent, TweenInfo.new(0.3, Enum.EasingStyle.Exponential), {BackgroundTransparency = 1})
local Tween1_3 = TweenService:Create(script.Parent, TweenInfo.new(0.3, Enum.EasingStyle.Exponential), {GroupTransparency = 1})
local Tween1_4 = TweenService:Create(script.Parent.Parent.UIScale, TweenInfo.new(0.6, Enum.EasingStyle.Exponential), {Scale = 1})
local Tween1_5 = TweenService:Create(script.Parent.Parent, TweenInfo.new(0.3, Enum.EasingStyle.Exponential), {BackgroundTransparency = 0})
local Tween1_6 = TweenService:Create(script.Parent, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {GroupTransparency = 0})

TDOS_SystemValues.VisibleSettingsMenuValue1.Changed:Connect(function(Value)
	if Value == false then
		Tween1_1:Play()
		Tween1_2:Play()
		Tween1_3:Play()
		
		Tween1_1.Completed:Connect(function()
			script.Parent.Parent.Visible = false
		end)
	elseif Value == true then
		script.Parent.Parent.Visible = true
		script.Parent.Parent.UIScale.Scale = 0.9
		
		Tween1_4:Play()
		Tween1_5:Play()
		
		Tween1_5.Completed:Connect(function()
			Tween1_6:Play()
		end)
	end
end)

--MenuCloseButton1

script.Parent.MenuCloseButton1.MouseButton1Click:Connect(function()
	TDOS_SystemValues.VisibleSettingsMenuValue1.Value = false
end)

--Frame1 Task

TDOS_SystemValues.DashboardPositionValue1.Changed:Connect(function(Value)
	RemoteEvent:FireServer("UDSData_DashboardPositionValue1", Value)
end)

--Frame2 Task

local Tween2_1 = TweenService:Create(SettingButtonsFrame1.Frame2.SliderSwitch1.SwitchHandleLabel1, TweenInfo.new(0.2, Enum.EasingStyle.Exponential), {BackgroundColor3 = Color3.fromRGB(255, 255, 255)})
local Tween2_2 = TweenService:Create(SettingButtonsFrame1.Frame2.SliderSwitch1.SwitchHandleLabel1, TweenInfo.new(0.2, Enum.EasingStyle.Exponential), {BackgroundColor3 = Color3.fromRGB(130, 130, 130)})

TDOS_SystemValues.LaunchpadPositionValue1.Changed:Connect(function(Value)
	RemoteEvent:FireServer("UDSData_LaunchpadPositionValue1", Value)
end)

TrainDrive_OS.TDOS_SystemValues.HideLaunchpadValue1.Changed:Connect(function(Value)
	if TDOS_SystemValues.LaunchpadDragValue1.Value == false then
		if Value == false then
			SettingButtonsFrame1.Frame2.SliderSwitch1.SliderSwitchScript.Enabled = true
			Tween2_1:Play()
		elseif Value == true then
			SettingButtonsFrame1.Frame2.SliderSwitch1.SliderSwitchScript.Enabled = false
			Tween2_2:Play()
		end
	end
end)

--Frame3 Task

SettingButtonsFrame1.Frame3.SettingButton1.MouseButton1Click:Connect(function()
	local Tween3_1 = TweenService:Create(SettingButtonsFrame1.Frame3.SettingButton1.ToggleSwitchLabel1.SwitchHandleLabel1, TweenInfo.new(0.2, Enum.EasingStyle.Exponential), {Position = UDim2.fromScale(0, -0.25)})
	local Tween3_2 = TweenService:Create(SettingButtonsFrame1.Frame3.SettingButton1.ToggleSwitchLabel1.SwitchHandleLabel1, TweenInfo.new(0.2, Enum.EasingStyle.Exponential), {Position = UDim2.fromScale(0.5, -0.25)})
	local Tween3_3 = TweenService:Create(SettingButtonsFrame1.Frame3.SettingButton1.ToggleSwitchLabel1, TweenInfo.new(0.2, Enum.EasingStyle.Exponential), {BackgroundColor3 = Color3.fromRGB(50, 50, 50)})
	local Tween3_4 = TweenService:Create(SettingButtonsFrame1.Frame3.SettingButton1.ToggleSwitchLabel1, TweenInfo.new(0.2, Enum.EasingStyle.Exponential), {BackgroundColor3 = Color3.fromRGB(75, 200, 100)})

	if TDOS_SystemValues.DashboardDragValue1.Value == false then
		TDOS_SystemValues.DashboardDragValue1.Value = true
		
		Tween3_2:Play()
		Tween3_4:Play()
	elseif TDOS_SystemValues.DashboardDragValue1.Value == true then
		TDOS_SystemValues.DashboardDragValue1.Value = false
		
		Tween3_1:Play()
		Tween3_3:Play()
	end
	
	RemoteEvent:FireServer("UDSData_DashboardDragValue1", TDOS_SystemValues.DashboardDragValue1.Value)
end)

--Frame4 Task

local Tween4_1 = TweenService:Create(SettingButtonsFrame1.Frame4.SettingButton1.ToggleSwitchLabel1.SwitchHandleLabel1, TweenInfo.new(0.2, Enum.EasingStyle.Exponential), {Position = UDim2.fromScale(0, -0.25)})
local Tween4_2 = TweenService:Create(SettingButtonsFrame1.Frame4.SettingButton1.ToggleSwitchLabel1.SwitchHandleLabel1, TweenInfo.new(0.2, Enum.EasingStyle.Exponential), {Position = UDim2.fromScale(0.5, -0.25)})
local Tween4_3 = TweenService:Create(SettingButtonsFrame1.Frame4.SettingButton1.ToggleSwitchLabel1, TweenInfo.new(0.2, Enum.EasingStyle.Exponential), {BackgroundColor3 = Color3.fromRGB(50, 50, 50)})
local Tween4_4 = TweenService:Create(SettingButtonsFrame1.Frame4.SettingButton1.ToggleSwitchLabel1, TweenInfo.new(0.2, Enum.EasingStyle.Exponential), {BackgroundColor3 = Color3.fromRGB(75, 200, 100)})

local Tween5_1 = TweenService:Create(SettingButtonsFrame1.Frame4.SettingButton1.ToggleSwitchLabel1.SwitchHandleLabel1, TweenInfo.new(0.2, Enum.EasingStyle.Exponential), {BackgroundColor3 = Color3.fromRGB(255, 255, 255)})
local Tween5_2 = TweenService:Create(SettingButtonsFrame1.Frame4.SettingButton1.ToggleSwitchLabel1.SwitchHandleLabel1, TweenInfo.new(0.2, Enum.EasingStyle.Exponential), {BackgroundColor3 = Color3.fromRGB(130, 130, 130)})

SettingButtonsFrame1.Frame4.SettingButton1.MouseButton1Click:Connect(function()
	if TDOS_SystemValues.HideLaunchpadValue1.Value == false then
		if TDOS_SystemValues.LaunchpadDragValue1.Value == false then
			TDOS_SystemValues.LaunchpadDragValue1.Value = true

			Tween4_2:Play()
			Tween4_4:Play()
		elseif TDOS_SystemValues.LaunchpadDragValue1.Value == true then
			TDOS_SystemValues.LaunchpadDragValue1.Value = false

			Tween4_1:Play()
			Tween4_3:Play()
		end	

		RemoteEvent:FireServer("UDSData_LaunchpadDragValue1", TDOS_SystemValues.LaunchpadDragValue1.Value)
	end
end)

TDOS_SystemValues.HideLaunchpadValue1.Changed:Connect(function(Value)
	if Value == false then
		Tween5_1:Play()
	elseif Value == true then
		Tween5_2:Play()
	end
end)

--Frame5 Task

local Tween6_1 = TweenService:Create(SettingButtonsFrame1.Frame5.SettingButton1.ToggleSwitchLabel1.SwitchHandleLabel1, TweenInfo.new(0.2, Enum.EasingStyle.Exponential), {Position = UDim2.fromScale(0, -0.25)})
local Tween6_2 = TweenService:Create(SettingButtonsFrame1.Frame5.SettingButton1.ToggleSwitchLabel1.SwitchHandleLabel1, TweenInfo.new(0.2, Enum.EasingStyle.Exponential), {Position = UDim2.fromScale(0.5, -0.25)})
local Tween6_3 = TweenService:Create(SettingButtonsFrame1.Frame5.SettingButton1.ToggleSwitchLabel1, TweenInfo.new(0.2, Enum.EasingStyle.Exponential), {BackgroundColor3 = Color3.fromRGB(50, 50, 50)})
local Tween6_4 = TweenService:Create(SettingButtonsFrame1.Frame5.SettingButton1.ToggleSwitchLabel1, TweenInfo.new(0.2, Enum.EasingStyle.Exponential), {BackgroundColor3 = Color3.fromRGB(75, 200, 100)})

SettingButtonsFrame1.Frame5.SettingButton1.MouseButton1Click:Connect(function()
	TDOS_SystemValues.HideLaunchpadValue1.Value = not TDOS_SystemValues.HideLaunchpadValue1.Value
	RemoteEvent:FireServer("UDSData_HideLaunchpadValue1", TDOS_SystemValues.HideLaunchpadValue1.Value)
end)

TDOS_SystemValues.HideLaunchpadValue1.Changed:Connect(function(Value)
	if Value == false then
		Tween6_1:Play()
		Tween6_3:Play()
	elseif Value == true then
		Tween6_2:Play()
		Tween6_4:Play()
	end
end)

--Frame6 Task

SettingButtonsFrame1.Frame6.SettingButton1.MouseButton1Click:Connect(function()
	if TDOS_SystemValues.LaunchpadButtonLayoutValue1.Value == 1 then
		TDOS_SystemValues.LaunchpadButtonLayoutValue1.Value = 2
	elseif TDOS_SystemValues.LaunchpadButtonLayoutValue1.Value == 2 then
		TDOS_SystemValues.LaunchpadButtonLayoutValue1.Value = 1
	end
	
	RemoteEvent:FireServer("UDSData_LaunchpadButtonLayoutValue1", TDOS_SystemValues.LaunchpadButtonLayoutValue1.Value)
end)

TDOS_SystemValues.LaunchpadButtonLayoutValue1.Changed:Connect(function(Value)
	if Value == 1 then
		SettingButtonsFrame1.Frame6.SettingButton1.TextLabel1.Text = "F/N/B"
	elseif Value == 2 then
		SettingButtonsFrame1.Frame6.SettingButton1.TextLabel1.Text = "B/N/F"
	end
end)

--Frame7 Task

SettingButtonsFrame1.Frame7.SettingButton1.MouseButton1Click:Connect(function()
	if TDOS_SystemValues.UILanguageValue1.Value == 1 then
		TDOS_SystemValues.UILanguageValue1.Value = 2
	elseif TDOS_SystemValues.UILanguageValue1.Value == 2 then
		TDOS_SystemValues.UILanguageValue1.Value = 1
	end
	
	RemoteEvent:FireServer("UDSData_UILanguageValue1", TDOS_SystemValues.UILanguageValue1.Value)
end)

--Frame8 Task

local Tween7_1 = TweenService:Create(script.Parent.Parent.Parent.TDOS_OtherFrames.KeyBindsMenuFrame1.UIScale, TweenInfo.new(0.6, Enum.EasingStyle.Exponential), {Scale = 1})
local Tween7_2 = TweenService:Create(script.Parent.Parent.Parent.TDOS_OtherFrames.KeyBindsMenuFrame1, TweenInfo.new(0.3, Enum.EasingStyle.Exponential), {BackgroundTransparency = 0})
local Tween7_3 = TweenService:Create(script.Parent.Parent.Parent.TDOS_OtherFrames.KeyBindsMenuFrame1.MainCG1, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {GroupTransparency = 0})

SettingButtonsFrame1.Frame8.SettingButton1.MouseButton1Click:Connect(function()
	if script.Parent.Parent.Parent.TDOS_OtherFrames.KeyBindsMenuFrame1.Visible == false then
		script.Parent.Parent.Parent.TDOS_OtherFrames.KeyBindsMenuFrame1.Visible = true
		script.Parent.Parent.Parent.TDOS_OtherFrames.KeyBindsMenuFrame1.UIScale.Scale = 0.9
		
		Tween7_1:Play()
		Tween7_2:Play()
		
		Tween7_2.Completed:Connect(function()
			Tween7_3:Play()
		end)
	end
end)

--LoadedSystemScriptsValue1 Task

TDOS_SystemValues.LoadedSystemScriptsValue1.Value = TDOS_SystemValues.LoadedSystemScriptsValue1.Value + 1

if script.Parent.Parent.Parent:FindFirstChild("EnableDebugLog") then
	print("Load Completed TDOS_SettingsMenu_MainScript | NT TDOS 5 Debug Log")
end

--End
]]></ProtectedString>
