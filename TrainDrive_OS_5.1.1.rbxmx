ActualSpeed.Changed:Connect(function(Value)
	script.Parent.TrainSpeedLabel1.Text = Value
end)

--Dashboard Position Tasks

TDOS_SystemValues.DashboardPositionValue1.Changed:Connect(function(Value)
	local DashboardXPosition
	
	if TDOS_SystemValues.HideLaunchpadValue1.Value == false then
		DashboardXPosition = 0.68
	elseif TDOS_SystemValues.HideLaunchpadValue1.Value == true then
		DashboardXPosition = 0.75
	end

	local Tween1 = TweenService:Create(script.Parent.Parent, TweenInfo.new(0.5, Enum.EasingStyle.Exponential), {Position = UDim2.fromScale(DashboardXPosition, 0.85)})
	local Tween2 = TweenService:Create(script.Parent.Parent, TweenInfo.new(0.5, Enum.EasingStyle.Exponential), {Position = UDim2.fromScale(DashboardXPosition, 0.9)})
	local Tween3 = TweenService:Create(script.Parent.Parent, TweenInfo.new(0.5, Enum.EasingStyle.Exponential), {Position = UDim2.fromScale(DashboardXPosition, 0.95)})
	local Tween4 = TweenService:Create(script.Parent.Parent, TweenInfo.new(0.5, Enum.EasingStyle.Bounce), {Position = UDim2.fromScale(DashboardXPosition, 1)})

	if Value == 1 then
		Tween1:Play()
	elseif Value == 2 then
		Tween2:Play()
	elseif Value == 3 then
		Tween3:Play()
	elseif Value == 4 then
		Tween4:Play()
	end

end)

