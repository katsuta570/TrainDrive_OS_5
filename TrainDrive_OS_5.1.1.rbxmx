local Tween6_1 = game:GetService("TweenService"):Create(script.Parent.Parent.MenuDragFrame1, TweenInfo.new(1, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out, 0, true), {BackgroundTransparency = 0.85})

TDOS_SystemValues.DashboardDragValue1.Changed:Connect(function(Value)
	if Value == true and RanDashboardMDFA == false then
		RanDashboardMDFA = true
		Tween6_1:Play()
	end
	
	if TDOS_SystemValues.DashboardDragValue1.Value == false then
		local Tween1 = TweenService:Create(script.Parent.Parent, TweenInfo.new(0.5, Enum.EasingStyle.Exponential), {Position = UDim2.new(0.68, 0, 0.85, 0)})
		local Tween2 = TweenService:Create(script.Parent.Parent, TweenInfo.new(0.5, Enum.EasingStyle.Exponential), {Position = UDim2.new(0.68, 0, 0.9, 0)})
		local Tween3 = TweenService:Create(script.Parent.Parent, TweenInfo.new(0.5, Enum.EasingStyle.Exponential), {Position = UDim2.new(0.68, 0, 0.95, 0)})
		local Tween4 = TweenService:Create(script.Parent.Parent, TweenInfo.new(0.5, Enum.EasingStyle.Exponential), {Position = UDim2.new(0.68, 0, 1, 0)})
		local Tween5 = TweenService:Create(script.Parent.Parent, TweenInfo.new(0.5, Enum.EasingStyle.Exponential), {Position = UDim2.new(0.75, 0, 0.85, 0)})
		local Tween6 = TweenService:Create(script.Parent.Parent, TweenInfo.new(0.5, Enum.EasingStyle.Exponential), {Position = UDim2.new(0.75, 0, 0.9, 0)})
