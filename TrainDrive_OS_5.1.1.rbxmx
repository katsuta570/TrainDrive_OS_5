			<Item class="Script" referent="RBX76219481285348ae8e49a4dfbd88fba2">
				<Properties>
					<ProtectedString name="Source"><![CDATA[--This script is for SmoothDrive Narikawa 4 and for TrainDrive OS 5 and for VehicleSeat1.
--このスクリプトは、SmoothDrive Narikawa 4・TrainDrive OS 5・VehicleSeat1用です。

script.Parent.ChildAdded:Connect(function(Child)
	script.Parent.Parent.VehicleSeat2.Disabled = true
	
	if Child.Name == "SeatWeld" then
		local Human = Child.Part1.Parent:FindFirstChild("Humanoid")
		
		if Human ~= nil then
			local TrainDrive_OS = script.Parent.Parent.Guis.TrainDrive_OS_5:Clone()
			
			TrainDrive_OS.TDOS_SystemValues.PlayerSeatValue1.Value = 1
			TrainDrive_OS.Parent = game.Players:FindFirstChild(Human.Parent.Name).PlayerGui
		end
	end
end)

script.Parent.ChildRemoved:Connect(function(Child)
	script.Parent.Parent.Values.AccelerationStateValue1.Value = 0
	script.Parent.Parent.Values.DecelerationStateValue1.Value = 0
	script.Parent.Parent.Values.ControlStateValue2.Value = 0
	script.Parent.Parent.Values.ControlMethodValue1.Value = 1
	script.Parent.Parent.Values.DirectionValue1.Value = 0
	script.Parent.Parent.Values.CurrentSpeedValue1.Value = 0
	
	script.Parent.Parent.VehicleSeat2.Disabled = false
	
	if Child.Name == "SeatWeld" then
		local Human = Child.Part1.Parent:FindFirstChild("Humanoid")
		
		if Human ~= nil then
			game.Players:FindFirstChild(Human.Parent.Name).PlayerGui.TrainDrive_OS_5:Destroy()
		end
	end
end)
]]></ProtectedString>
