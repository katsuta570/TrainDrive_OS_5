--TrainThrottleLabel1 Tasks

local Tween3_1 = TweenService:Create(script.Parent.TrainThrottleLabel1.MCModeTextLabelsCG1, TweenInfo.new(0.07, Enum.EasingStyle.Linear), {GroupTransparency = 1})
local Tween3_2 = TweenService:Create(script.Parent.TrainThrottleLabel1.MCModeTextLabelsCG1, TweenInfo.new(0.07, Enum.EasingStyle.Linear), {GroupTransparency = 0})
local Tween3_3 = TweenService:Create(script.Parent.TrainThrottleLabel1.WASDModeTextLabelsCG1, TweenInfo.new(0.07, Enum.EasingStyle.Linear), {GroupTransparency = 1})
local Tween3_4 = TweenService:Create(script.Parent.TrainThrottleLabel1.WASDModeTextLabelsCG1, TweenInfo.new(0.07, Enum.EasingStyle.Linear), {GroupTransparency = 0})

local function ToUpWASDModeThrottleTextLabel1(TextLabel)
	local Tween1 = TweenService:Create(TextLabel, TweenInfo.new(0.2, Enum.EasingStyle.Exponential), {Position = UDim2.fromScale(0.25, -0.5), Size = UDim2.fromScale(0.5, 0.5)})
	Tween1:Play()
end

local function ToCenterWASDModeThrottleTextLabel1(TextLabel)
	local Tween1 = TweenService:Create(TextLabel, TweenInfo.new(0.2, Enum.EasingStyle.Exponential), {Position = UDim2.fromScale(0, 0), Size = UDim2.fromScale(1, 1)})
	Tween1:Play()
end

local function ToDownWASDModeThrottleTextLabel1(TextLabel)
	local Tween1 = TweenService:Create(TextLabel, TweenInfo.new(0.2, Enum.EasingStyle.Exponential), {Position = UDim2.fromScale(0.25, 1), Size = UDim2.fromScale(0.5, 0.5)})
	Tween1:Play()
end

local function ToMCModeCenterThrottleTextLabel1(TextLabel1)
	local UpperNotches = {}
	local LowerNotches = {}
	
	local Tween1 = TweenService:Create(TextLabel1, TweenInfo.new(0.2, Enum.EasingStyle.Exponential), {Position = UDim2.fromScale(0, 0), Size = UDim2.fromScale(1, 1)})
	Tween1:Play()
	
	for _, TextLabel2 in ipairs(script.Parent.TrainThrottleLabel1.MCModeTextLabelsCG1:GetChildren()) do
		if TextLabel2.Name ~= TextLabel1.Name then
			if TextLabel2.NotchOrderValue1.Value > TextLabel1.NotchOrderValue1.Value then
				table.insert(UpperNotches, TextLabel2)
				
				local Tween3 = TweenService:Create(TextLabel2, TweenInfo.new(0.2, Enum.EasingStyle.Exponential), {Position = UDim2.fromScale(0.25, -0.5), Size = UDim2.fromScale(0.5, 0.5)})
				Tween3:Play()
			elseif TextLabel2.NotchOrderValue1.Value < TextLabel1.NotchOrderValue1.Value then
				table.insert(LowerNotches, TextLabel2)
				
				local Tween5 = TweenService:Create(TextLabel2, TweenInfo.new(0.2, Enum.EasingStyle.Exponential), {Position = UDim2.fromScale(0.25, 1), Size = UDim2.fromScale(0.5, 0.5)})
				Tween5:Play()
			end
		end
	end
	
	if script.Parent.Parent.Parent:FindFirstChild("Enabled_Debug_Mode") then
		print(UpperNotches)
		print(LowerNotches)
	end
end

local function ReloadTrainThrottleLabel1()
	if ControlMethod.Value == 1 then
		if WASDModeNotch.Value == 0 and EmergencyBrake.Value == false then
			ToUpWASDModeThrottleTextLabel1(script.Parent.TrainThrottleLabel1.WASDModeTextLabelsCG1.TextLabel1)
			ToCenterWASDModeThrottleTextLabel1(script.Parent.TrainThrottleLabel1.WASDModeTextLabelsCG1.TextLabel2)
			ToDownWASDModeThrottleTextLabel1(script.Parent.TrainThrottleLabel1.WASDModeTextLabelsCG1.TextLabel3)
			ToDownWASDModeThrottleTextLabel1(script.Parent.TrainThrottleLabel1.WASDModeTextLabelsCG1.TextLabel4)
		elseif WASDModeNotch.Value == 1 and EmergencyBrake.Value == false then
			ToCenterWASDModeThrottleTextLabel1(script.Parent.TrainThrottleLabel1.WASDModeTextLabelsCG1.TextLabel1)
			ToDownWASDModeThrottleTextLabel1(script.Parent.TrainThrottleLabel1.WASDModeTextLabelsCG1.TextLabel2)
			ToDownWASDModeThrottleTextLabel1(script.Parent.TrainThrottleLabel1.WASDModeTextLabelsCG1.TextLabel3)
			ToDownWASDModeThrottleTextLabel1(script.Parent.TrainThrottleLabel1.WASDModeTextLabelsCG1.TextLabel4)
		elseif WASDModeNotch.Value == -1 and EmergencyBrake.Value == false then
			ToUpWASDModeThrottleTextLabel1(script.Parent.TrainThrottleLabel1.WASDModeTextLabelsCG1.TextLabel1)
			ToUpWASDModeThrottleTextLabel1(script.Parent.TrainThrottleLabel1.WASDModeTextLabelsCG1.TextLabel2)
			ToCenterWASDModeThrottleTextLabel1(script.Parent.TrainThrottleLabel1.WASDModeTextLabelsCG1.TextLabel3)
			ToDownWASDModeThrottleTextLabel1(script.Parent.TrainThrottleLabel1.WASDModeTextLabelsCG1.TextLabel4)
		elseif EmergencyBrake.Value == true then
			ToUpWASDModeThrottleTextLabel1(script.Parent.TrainThrottleLabel1.WASDModeTextLabelsCG1.TextLabel1)
			ToUpWASDModeThrottleTextLabel1(script.Parent.TrainThrottleLabel1.WASDModeTextLabelsCG1.TextLabel2)
			ToUpWASDModeThrottleTextLabel1(script.Parent.TrainThrottleLabel1.WASDModeTextLabelsCG1.TextLabel3)
			ToCenterWASDModeThrottleTextLabel1(script.Parent.TrainThrottleLabel1.WASDModeTextLabelsCG1.TextLabel4)
		end
	elseif ControlMethod.Value == 2 then
		if MasterControlNotch.Value == 8 then ToMCModeCenterThrottleTextLabel1(script.Parent.TrainThrottleLabel1.MCModeTextLabelsCG1.TextLabel_EB_1) end
		if MasterControlNotch.Value == 7 then ToMCModeCenterThrottleTextLabel1(script.Parent.TrainThrottleLabel1.MCModeTextLabelsCG1.TextLabel_B7_1) end
		if MasterControlNotch.Value == 6 then ToMCModeCenterThrottleTextLabel1(script.Parent.TrainThrottleLabel1.MCModeTextLabelsCG1.TextLabel_B6_1) end
		if MasterControlNotch.Value == 5 then ToMCModeCenterThrottleTextLabel1(script.Parent.TrainThrottleLabel1.MCModeTextLabelsCG1.TextLabel_B5_1) end
		if MasterControlNotch.Value == 4 then ToMCModeCenterThrottleTextLabel1(script.Parent.TrainThrottleLabel1.MCModeTextLabelsCG1.TextLabel_B4_1) end
		if MasterControlNotch.Value == 3 then ToMCModeCenterThrottleTextLabel1(script.Parent.TrainThrottleLabel1.MCModeTextLabelsCG1.TextLabel_B3_1) end
		if MasterControlNotch.Value == 2 then ToMCModeCenterThrottleTextLabel1(script.Parent.TrainThrottleLabel1.MCModeTextLabelsCG1.TextLabel_B2_1) end
		if MasterControlNotch.Value == 1 then ToMCModeCenterThrottleTextLabel1(script.Parent.TrainThrottleLabel1.MCModeTextLabelsCG1.TextLabel_B1_1) end
		
		if MasterControlNotch.Value == 0 then ToMCModeCenterThrottleTextLabel1(script.Parent.TrainThrottleLabel1.MCModeTextLabelsCG1.TextLabel_N_1) end
		
		if MasterControlNotch.Value == -1 then ToMCModeCenterThrottleTextLabel1(script.Parent.TrainThrottleLabel1.MCModeTextLabelsCG1.TextLabel_P1_1) end
		if MasterControlNotch.Value == -2 then ToMCModeCenterThrottleTextLabel1(script.Parent.TrainThrottleLabel1.MCModeTextLabelsCG1.TextLabel_P2_1) end
		if MasterControlNotch.Value == -3 then ToMCModeCenterThrottleTextLabel1(script.Parent.TrainThrottleLabel1.MCModeTextLabelsCG1.TextLabel_P3_1) end
		if MasterControlNotch.Value == -4 then ToMCModeCenterThrottleTextLabel1(script.Parent.TrainThrottleLabel1.MCModeTextLabelsCG1.TextLabel_P4_1) end
		if MasterControlNotch.Value == -5 then ToMCModeCenterThrottleTextLabel1(script.Parent.TrainThrottleLabel1.MCModeTextLabelsCG1.TextLabel_P5_1) end
	end
end

WASDModeNotch.Changed:Connect(function()
	ReloadTrainThrottleLabel1()
end)

MasterControlNotch.Changed:Connect(function()
	ReloadTrainThrottleLabel1()
end)

EmergencyBrake.Changed:Connect(function()
	ReloadTrainThrottleLabel1()
end)

ControlMethod.Changed:Connect(function(Value)
	if Value == 1 then
		Tween3_1:Play()
		
		Tween3_1.Completed:Connect(function()
			Tween3_4:Play()
		end)
	elseif Value == 2 then
		Tween3_3:Play()
		
		Tween3_3.Completed:Connect(function()
			Tween3_2:Play()
		end)
	end
	
	ReloadTrainThrottleLabel1()
end)

if ControlMethod.Value == 1 then
	script.Parent.TrainThrottleLabel1.MCModeTextLabelsCG1.GroupTransparency = 1
	script.Parent.TrainThrottleLabel1.WASDModeTextLabelsCG1.GroupTransparency = 0
elseif ControlMethod.Value == 2 then
	script.Parent.TrainThrottleLabel1.MCModeTextLabelsCG1.GroupTransparency = 0
	script.Parent.TrainThrottleLabel1.WASDModeTextLabelsCG1.GroupTransparency = 1
end

ReloadTrainThrottleLabel1()

