--Variables

local RanLaunchpadMDFA = false
local RemoteEvent = script.Parent.Parent.Parent.TDOS_SystemScripts.RemoteEvent
local TDOS_SystemValues = script.Parent.Parent.Parent.TDOS_SystemValues
local TweenService = game:GetService("TweenService")

--ControlButtons Tasks

script.Parent.ControlButton1.MouseButton1Click:Connect(function()
	RemoteEvent:FireServer("PressData_MCN_Down")
end)

script.Parent.ControlButton2.MouseButton1Click:Connect(function()
	RemoteEvent:FireServer("PressData_MCN_Neutral")
end)

script.Parent.ControlButton3.MouseButton1Click:Connect(function()
	RemoteEvent:FireServer("PressData_MCN_Up")
end)

--LaunchpadButtonLayoutValue1 Task

local Tween1_1 = TweenService:Create(script.Parent.ControlButton1, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {BackgroundTransparency = 1})
local Tween1_2 = TweenService:Create(script.Parent.ControlButton1, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {BackgroundTransparency = 0})
local Tween1_3 = TweenService:Create(script.Parent.ControlButton1.TextLabel1, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {TextTransparency = 1})
local Tween1_4 = TweenService:Create(script.Parent.ControlButton1.TextLabel1, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {TextTransparency = 0})

local Tween1_5 = TweenService:Create(script.Parent.ControlButton2, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {BackgroundTransparency = 1})
local Tween1_6 = TweenService:Create(script.Parent.ControlButton2, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {BackgroundTransparency = 0})
local Tween1_7 = TweenService:Create(script.Parent.ControlButton2.TextLabel1, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {TextTransparency = 1})
local Tween1_8 = TweenService:Create(script.Parent.ControlButton2.TextLabel1, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {TextTransparency = 0})

local Tween1_9 = TweenService:Create(script.Parent.ControlButton3, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {BackgroundTransparency = 1})
local Tween1_10 = TweenService:Create(script.Parent.ControlButton3, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {BackgroundTransparency = 0})
local Tween1_11 = TweenService:Create(script.Parent.ControlButton3.TextLabel1, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {TextTransparency = 1})
local Tween1_12 = TweenService:Create(script.Parent.ControlButton3.TextLabel1, TweenInfo.new(0.1, Enum.EasingStyle.Linear), {TextTransparency = 0})

TDOS_SystemValues.LaunchpadButtonLayoutValue1.Changed:Connect(function(Value)
	Tween1_1:Play()
	Tween1_3:Play()
	Tween1_5:Play()
	Tween1_7:Play()
	Tween1_9:Play()
	Tween1_11:Play()
	
	Tween1_11.Completed:Connect(function()
		if script.Parent.Parent.Parent.TDOS_SystemValues.LaunchpadButtonLayoutValue1.Value == 1 then
			script.Parent.ControlButton1.Position = UDim2.fromScale(0.1, 0.08)
			script.Parent.ControlButton3.Position = UDim2.fromScale(0.1, 0.64)
			
			Tween1_2:Play()
			Tween1_4:Play()
			Tween1_6:Play()
			Tween1_8:Play()
			Tween1_10:Play()
			Tween1_12:Play()
		elseif script.Parent.Parent.Parent.TDOS_SystemValues.LaunchpadButtonLayoutValue1.Value == 2 then
			script.Parent.ControlButton1.Position = UDim2.fromScale(0.1, 0.64)
			script.Parent.ControlButton3.Position = UDim2.fromScale(0.1, 0.08)
			
			Tween1_2:Play()
			Tween1_4:Play()
			Tween1_6:Play()
			Tween1_8:Play()
			Tween1_10:Play()
			Tween1_12:Play()
		end
	end)
end)

--HideLaunchpadValue1 Task

local Tween3_1 = TweenService:Create(script.Parent.Parent.UIScale, TweenInfo.new(0.6, Enum.EasingStyle.Exponential), {Scale = 1})
local Tween3_2 = TweenService:Create(script.Parent.Parent, TweenInfo.new(0.3, Enum.EasingStyle.Exponential), {BackgroundTransparency = 0})
local Tween3_3 = TweenService:Create(script.Parent, TweenInfo.new(0.2, Enum.EasingStyle.Quad), {GroupTransparency = 0})
local Tween3_4 = TweenService:Create(script.Parent.Parent.UIScale, TweenInfo.new(0.5, Enum.EasingStyle.Exponential), {Scale = 0.9})
local Tween3_5 = TweenService:Create(script.Parent.Parent, TweenInfo.new(0.3, Enum.EasingStyle.Exponential), {BackgroundTransparency = 1})
local Tween3_6 = TweenService:Create(script.Parent, TweenInfo.new(0.3, Enum.EasingStyle.Exponential), {GroupTransparency = 1})

TDOS_SystemValues.HideLaunchpadValue1.Changed:Connect(function(Value)
	if Value == false then
		script.Parent.Visible = true
		script.Parent.Parent.UIScale.Scale = 0.9
		
		script.Parent.Parent.MenuDragFrame1.Interactable = true
		
		Tween3_1:Play()
		Tween3_2:Play()
		
		Tween3_2.Completed:Connect(function()
			Tween3_3:Play()
		end)
	elseif Value == true then
		script.Parent.Parent.MenuDragFrame1.Interactable = false
		
		Tween3_4:Play()
		Tween3_5:Play()
		Tween3_6:Play()
		
		Tween3_4.Completed:Connect(function()
			script.Parent.Visible = false
		end)
	end
end)

--Launchpad Position Tasks

local Tween2_1 = TweenService:Create(script.Parent.Parent, TweenInfo.new(0.5, Enum.EasingStyle.Exponential), {Position = UDim2.fromScale(0.72, 0.85)})
local Tween2_2 = TweenService:Create(script.Parent.Parent, TweenInfo.new(0.5, Enum.EasingStyle.Exponential), {Position = UDim2.fromScale(0.72, 0.9)})
local Tween2_3 = TweenService:Create(script.Parent.Parent, TweenInfo.new(0.5, Enum.EasingStyle.Exponential), {Position = UDim2.fromScale(0.72, 0.95)})
local Tween2_4 = TweenService:Create(script.Parent.Parent, TweenInfo.new(0.5, Enum.EasingStyle.Bounce), {Position = UDim2.fromScale(0.72, 1)})
local Tween2_5 = TweenService:Create(script.Parent.Parent, TweenInfo.new(0.5, Enum.EasingStyle.Exponential), {Position = UDim2.fromScale(0.72, 1)})

TDOS_SystemValues.LaunchpadPositionValue1.Changed:Connect(function(Value)
	if Value == 1 then
		Tween2_1:Play()
	elseif Value == 2 then
		Tween2_2:Play()
	elseif Value == 3 then
		Tween2_3:Play()
	elseif Value == 4 then
		Tween2_4:Play()
	end
end)

TDOS_SystemValues.LaunchpadDragValue1.Changed:Connect(function(Value)
	if Value == false then
		if TDOS_SystemValues.LaunchpadPositionValue1.Value == 1 then
			Tween2_1:Play()
		elseif TDOS_SystemValues.LaunchpadPositionValue1.Value == 2 then
			Tween2_2:Play()
		elseif TDOS_SystemValues.LaunchpadPositionValue1.Value == 3 then
			Tween2_3:Play()
		elseif TDOS_SystemValues.LaunchpadPositionValue1.Value == 4 then
			Tween2_5:Play()
		end
	end
end)

--MenuDragFrame1 Animation Task

local Tween3_1 = game:GetService("TweenService"):Create(script.Parent.Parent.MenuDragFrame1, TweenInfo.new(1, Enum.EasingStyle.Exponential, Enum.EasingDirection.Out, 0, true), {BackgroundTransparency = 0.85})

TDOS_SystemValues.LaunchpadDragValue1.Changed:Connect(function(Value)
	if Value == true and script.Parent.Parent.MenuDragFrame1.Interactable == true and RanLaunchpadMDFA == false then
		RanLaunchpadMDFA = true
		Tween3_1:Play()
	end
end)

--LoadedSystemScriptsValue1 Task

TDOS_SystemValues.LoadedSystemScriptsValue1.Value = TDOS_SystemValues.LoadedSystemScriptsValue1.Value + 1

if script.Parent.Parent.Parent:FindFirstChild("EnableDebugLog") then
	print("Load Completed TDOS_Launchpad_MainScript | NT TDOS 5 Debug Log")
end

--End
]]></ProtectedString>
