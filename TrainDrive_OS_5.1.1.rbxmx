			elseif Objects.Name == "TextLabel1_CBI" then
				Objects.FontFace = Font.fromName("RobotoCondensed", Enum.FontWeight.Bold, Enum.FontStyle.Italic)
			elseif Objects.Name == "TextLabel1_CRN" then
				Objects.FontFace = Font.fromName("RobotoCondensed", Enum.FontWeight.Regular, Enum.FontStyle.Normal)
			end
		end
	elseif Value == 2 then
		DashboardFrame1.CommBuzzerButton1.TextLabel1_BI.Text = "ブザー"
		DashboardFrame1.DeleteTrainButton1.TextLabel1_BI.Text = "列車を削除"
