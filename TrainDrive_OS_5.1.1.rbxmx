local function ToUpDirectionTextLabel1(TextLabel)
	local Tween1 = TweenService:Create(TextLabel, TweenInfo.new(0.2, Enum.EasingStyle.Exponential), {Position = UDim2.fromScale(0.25, -0.5)})
	local Tween2 = TweenService:Create(TextLabel, TweenInfo.new(0.2, Enum.EasingStyle.Exponential), {Size = UDim2.fromScale(0.5, 0.5)})
	
	Tween1:Play()
	Tween2:Play()
end

local function ToCenterDirectionTextLabel1(TextLabel)
	local Tween1 = TweenService:Create(TextLabel, TweenInfo.new(0.2, Enum.EasingStyle.Exponential), {Position = UDim2.fromScale(0, 0)})
	local Tween2 = TweenService:Create(TextLabel, TweenInfo.new(0.2, Enum.EasingStyle.Exponential), {Size = UDim2.fromScale(1, 1)})
	
	Tween1:Play()
	Tween2:Play()
end

local function ToDownDirectionTextLabel1(TextLabel)
	local Tween1 = TweenService:Create(TextLabel, TweenInfo.new(0.2, Enum.EasingStyle.Exponential), {Position = UDim2.fromScale(0.25, 1)})
	local Tween2 = TweenService:Create(TextLabel, TweenInfo.new(0.2, Enum.EasingStyle.Exponential), {Size = UDim2.fromScale(0.5, 0.5)})
	
	Tween1:Play()
	Tween2:Play()
end

Direction.Changed:Connect(function(Value)
	if TDOS_SystemValues.PlayerSeatValue1.Value == 1 then
		if Value == 0 then
			ToUpDirectionTextLabel1(script.Parent.TrainDirectionLabel1.TextLabelFrame1.TextLabel1)
			ToCenterDirectionTextLabel1(script.Parent.TrainDirectionLabel1.TextLabelFrame1.TextLabel2)
			ToDownDirectionTextLabel1(script.Parent.TrainDirectionLabel1.TextLabelFrame1.TextLabel3)
		elseif Value == 1 then
			ToCenterDirectionTextLabel1(script.Parent.TrainDirectionLabel1.TextLabelFrame1.TextLabel1)
			ToDownDirectionTextLabel1(script.Parent.TrainDirectionLabel1.TextLabelFrame1.TextLabel2)
			ToDownDirectionTextLabel1(script.Parent.TrainDirectionLabel1.TextLabelFrame1.TextLabel3)
		elseif Value == -1 then
			ToUpDirectionTextLabel1(script.Parent.TrainDirectionLabel1.TextLabelFrame1.TextLabel1)
			ToUpDirectionTextLabel1(script.Parent.TrainDirectionLabel1.TextLabelFrame1.TextLabel2)
			ToCenterDirectionTextLabel1(script.Parent.TrainDirectionLabel1.TextLabelFrame1.TextLabel3)
		end
	elseif TDOS_SystemValues.PlayerSeatValue1.Value == 2 then
		if Value == 0 then
			ToUpDirectionTextLabel1(script.Parent.TrainDirectionLabel1.TextLabelFrame1.TextLabel1)
			ToCenterDirectionTextLabel1(script.Parent.TrainDirectionLabel1.TextLabelFrame1.TextLabel2)
			ToDownDirectionTextLabel1(script.Parent.TrainDirectionLabel1.TextLabelFrame1.TextLabel3)
		elseif Value == 1 then
			ToUpDirectionTextLabel1(script.Parent.TrainDirectionLabel1.TextLabelFrame1.TextLabel1)
			ToUpDirectionTextLabel1(script.Parent.TrainDirectionLabel1.TextLabelFrame1.TextLabel2)
			ToCenterDirectionTextLabel1(script.Parent.TrainDirectionLabel1.TextLabelFrame1.TextLabel3)
		elseif Value == -1 then
			ToCenterDirectionTextLabel1(script.Parent.TrainDirectionLabel1.TextLabelFrame1.TextLabel1)
			ToDownDirectionTextLabel1(script.Parent.TrainDirectionLabel1.TextLabelFrame1.TextLabel2)
			ToDownDirectionTextLabel1(script.Parent.TrainDirectionLabel1.TextLabelFrame1.TextLabel3)
		end
	end
end)

local Tween2_1 = TweenService:Create(script.Parent.TrainDirectionLabel1.TrainDirectionUpButton1, TweenInfo.new(0.2, Enum.EasingStyle.Linear), {BackgroundTransparency = 1})
local Tween2_2 = TweenService:Create(script.Parent.TrainDirectionLabel1.TrainDirectionUpButton1, TweenInfo.new(0.2, Enum.EasingStyle.Linear), {BackgroundTransparency = 0})
local Tween2_3 = TweenService:Create(script.Parent.TrainDirectionLabel1.TrainDirectionDownButton1, TweenInfo.new(0.2, Enum.EasingStyle.Linear), {BackgroundTransparency = 1})
local Tween2_4 = TweenService:Create(script.Parent.TrainDirectionLabel1.TrainDirectionDownButton1, TweenInfo.new(0.2, Enum.EasingStyle.Linear), {BackgroundTransparency = 0})

