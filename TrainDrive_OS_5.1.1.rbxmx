						<Item class="LocalScript" referent="RBXf11d45c10c2d4f86a25e1193bd286190">
							<Properties>
								<ProtectedString name="Source"><![CDATA[local Tween1_1 = game:GetService("TweenService"):Create(script.Parent.Parent.UIScale, TweenInfo.new(0.5, Enum.EasingStyle.Exponential), {Scale = 0.9})
local Tween1_2 = game:GetService("TweenService"):Create(script.Parent.Parent, TweenInfo.new(0.3, Enum.EasingStyle.Exponential), {BackgroundTransparency = 1})
local Tween1_3 = game:GetService("TweenService"):Create(script.Parent, TweenInfo.new(0.3, Enum.EasingStyle.Exponential), {GroupTransparency = 1})

script.Parent.MenuCloseButton1.MouseButton1Click:Connect(function(Value)
	Tween1_1:Play()
	Tween1_2:Play()
	Tween1_3:Play()
	
	Tween1_1.Completed:Connect(function()
		script.Parent.Parent.Visible = false
	end)
end)
]]></ProtectedString>
