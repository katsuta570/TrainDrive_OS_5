		if BogieInstancesModuleScript.ControlMethod.Value == 1 then
			DashboardFrame1.ControlMethodSwitchButton1.TextLabel1_CBI.Text = "マスコン操作にする"
		elseif BogieInstancesModuleScript.ControlMethod.Value == 2 then
			DashboardFrame1.ControlMethodSwitchButton1.TextLabel1_CBI.Text = "WASD操作にする"
		end
		
		script.Parent.Parent.LaunchpadFrame1.MainCG1.TextLabel1_RobotoBI.Text = "加速 / 減速"

		SettingsMenuFrame1.Frame1.TextLabel1_SBN.Text = "Dashboard 表示位置"
		SettingsMenuFrame1.Frame1.TextLabel1_RN.Text = "Dashboardの表示位置を選択。"
		SettingsMenuFrame1.Frame2.TextLabel1_SBN.Text = "Launchpad 表示位置"
