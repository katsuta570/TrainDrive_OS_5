		<Item class="Script" referent="RBXd8f3b8329cea4fec832b4d1e7ca515b3">
			<Properties>
				<ProtectedString name="Source"><![CDATA[--[[

Credit...

TDOS_5_DataStoreScript

Version: 5.1.1

Last Update: 2026.03.04

License: GNU General Public License v3.0 or later

Description: DataStore handling script for TrainDrive OS 5.1.1.

Created by: Narikawa Technology (https://narikawatechnology.studio.site, https://www.roblox.com/groups/34730917)

Contact: Discord - manjunewmanzyu, X - gen3manju

]]

--[[

License...

Copyright (C) 2026 Narikawa Technology

This file is part of TrainDrive OS.

This program is free software: you can redistribute it and/or modify it under the terms of the GNU General Public License as published by the Free Software Foundation, either version 3 of the License, or (at your option) any later version.
This program is distributed in the hope that it will be useful, but WITHOUT ANY WARRANTY; without even the implied warranty of MERCHANTABILITY or FITNESS FOR A PARTICULAR PURPOSE. See the GNU General Public License for more details.
You should have received a copy of the GNU General Public License along with this program. If not, see <https://www.gnu.org/licenses/>.

]]

local PlayerDataStore
local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

if not RunService:IsStudio() then
	PlayerDataStore = game:GetService("DataStoreService"):GetDataStore("TDOS_5_DataStore")
else
	warn("Studio Mode Enabled | NT TDOS 5 DataStoreScript")
end

Players.PlayerAdded:Connect(function(Player)
	local Folder1 = Instance.new("Folder")
	Folder1.Parent = Player
	Folder1.Name = "TDOS_5_DataStoreValues"
	local DashboardDragValue1 = Instance.new("BoolValue", Folder1)
	DashboardDragValue1.Name = "DashboardDragValue1"
	local DashboardPositionValue1 = Instance.new("NumberValue", Folder1)
	DashboardPositionValue1.Name = "DashboardPositionValue1"
	local HideLaunchpadValue1 = Instance.new("BoolValue", Folder1)
	HideLaunchpadValue1.Name = "HideLaunchpadValue1"
	local LaunchpadButtonLayoutValue1 = Instance.new("NumberValue", Folder1)
	LaunchpadButtonLayoutValue1.Name = "LaunchpadButtonLayoutValue1"
	local LaunchpadDragValue1 = Instance.new("BoolValue", Folder1)
	LaunchpadDragValue1.Name = "LaunchpadDragValue1"
	local LaunchpadPositionValue1 = Instance.new("NumberValue", Folder1)
	LaunchpadPositionValue1.Name = "LaunchpadPositionValue1"
	local UILanguageValue1 = Instance.new("NumberValue", Folder1)
	UILanguageValue1.Name = "UILanguageValue1"
	
	
	DashboardDragValue1.Value = false
	DashboardPositionValue1.Value = 1
	HideLaunchpadValue1.Value = false
	LaunchpadButtonLayoutValue1.Value = 1
	LaunchpadDragValue1.Value = false
	LaunchpadPositionValue1.Value = 1
	UILanguageValue1.Value = 1
	
	if RunService:IsStudio() then
		return
	end
	
	local Success, StoredData = pcall(function()
		return PlayerDataStore:GetAsync(Player.UserId)
	end)
	
	if Success and StoredData then
		DashboardDragValue1.Value = StoredData[1]
		DashboardPositionValue1.Value = StoredData[2]
		HideLaunchpadValue1.Value = StoredData[3]
		LaunchpadButtonLayoutValue1.Value = StoredData[4]
		LaunchpadDragValue1.Value = StoredData[5]
		LaunchpadPositionValue1.Value = StoredData[6]
		UILanguageValue1.Value = StoredData[7]
	end
end)

Players.PlayerRemoving:Connect(function(Player)
	if RunService:IsStudio() then
		return
	end
	
	local Values = {
		Player.TDOS_5_DataStoreValues.DashboardDragValue1.Value,
		Player.TDOS_5_DataStoreValues.DashboardPositionValue1.Value,
		Player.TDOS_5_DataStoreValues.HideLaunchpadValue1.Value,
		Player.TDOS_5_DataStoreValues.LaunchpadButtonLayoutValue1.Value,
		Player.TDOS_5_DataStoreValues.LaunchpadDragValue1.Value,
		Player.TDOS_5_DataStoreValues.LaunchpadPositionValue1.Value,
		Player.TDOS_5_DataStoreValues.UILanguageValue1.Value,
	}
	
	local Success, ErrorMessage = pcall(function()
		PlayerDataStore:SetAsync(Player.UserId, Values)
	end)
end)
]]></ProtectedString>
