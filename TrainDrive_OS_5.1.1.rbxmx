								<Item class="LocalScript" referent="RBX283f8033885342dfbb86fd7db098827e">
									<Properties>
										<ProtectedString name="Source"><![CDATA[local ChangeValue = script.Parent.Parent.Parent.Parent.Parent.Parent.TDOS_SystemValues.DashboardPositionValue1
local Dragging = false

local function BlockCameraAction(ActionName, InputState, InputObject)
	return Enum.ContextActionResult.Sink
end

local function StartDragging()
	Dragging = true
	game:GetService("ContextActionService"):BindAction(
		"DisableCameraMovement",
		BlockCameraAction,
		false,
		Enum.UserInputType.Touch,
		Enum.UserInputType.MouseMovement
	)
end

local function StopDragging()
	Dragging = false
	game:GetService("ContextActionService"):UnbindAction("DisableCameraMovement")
end

script.Parent.InputBegan:Connect(function(Input)
	if Input.UserInputType == Enum.UserInputType.Touch or Input.UserInputType == Enum.UserInputType.MouseButton1 then
		StartDragging()
		script.Parent.SwitchHandleLabel1.CurrentLevelLabel1.Visible = true
	end
end)

game:GetService("UserInputService").InputEnded:Connect(function(Input)
	if Input.UserInputType == Enum.UserInputType.Touch or Input.UserInputType == Enum.UserInputType.MouseButton1 then
		StopDragging()
		script.Parent.SwitchHandleLabel1.CurrentLevelLabel1.Visible = false
	end
end)

game:GetService("UserInputService").InputChanged:Connect(function(InputObject)
	if Dragging and (InputObject.UserInputType == Enum.UserInputType.MouseMovement or InputObject.UserInputType == Enum.UserInputType.Touch) then
		local RelativeX = InputObject.Position.X - script.Parent.AbsolutePosition.X
		local Segment = script.Parent.AbsoluteSize.X / 4
		local Stage = 1
		
		if RelativeX < 0 then
			RelativeX = 0
		elseif RelativeX > script.Parent.AbsoluteSize.X then
			RelativeX = script.Parent.AbsoluteSize.X
		end
		
		if RelativeX <= Segment then
			Stage = 1
		elseif RelativeX <= Segment * 2 then
			Stage = 2
		elseif RelativeX <= Segment * 3 then
			Stage = 3
		else
			Stage = 4
		end
		
		local ScaleValue = (Stage - 1) * 0.25
		
		ChangeValue.Value = Stage
		
		script.Parent.SwitchHandleLabel1.Position = UDim2.new(ScaleValue, 0, script.Parent.SwitchHandleLabel1.Position.Y.Scale, script.Parent.SwitchHandleLabel1.Position.Y.Offset)
		script.Parent.SwitchHandleLabel1.CurrentLevelLabel1.Text = Stage
	end
end)

ChangeValue.Changed:Connect(function(Stage)
	local ScaleValue = (Stage - 1) * 0.25
	
	script.Parent.SwitchHandleLabel1.Position = UDim2.new(
		ScaleValue,
		0,
		script.Parent.SwitchHandleLabel1.Position.Y.Scale,
		script.Parent.SwitchHandleLabel1.Position.Y.Offset
	)
	
	script.Parent.SwitchHandleLabel1.CurrentLevelLabel1.Text = Stage
end)
]]></ProtectedString>
