				<Item class="LocalScript" referent="RBXe4184824bc3c4cbb9aec4658aed6129d">
					<Properties>
						<ProtectedString name="Source"><![CDATA[local LocalPlayer = game:GetService("Players").LocalPlayer
local TweenService = game:GetService("TweenService")
local TDOS_Module_Script = require(script.Parent.Parent.TDOS_ModuleScript)
local TrainDrive_OS = script.Parent.Parent
local TDOS_SystemValues = script.Parent.Parent.TDOS_SystemValues

TrainDrive_OS.DashboardFrame1.BackgroundTransparency = 1
TrainDrive_OS.DashboardFrame1.MainCG1.GroupTransparency = 1
TrainDrive_OS.DashboardFrame1.Visible = false

TrainDrive_OS.LaunchpadFrame1.BackgroundTransparency = 1
TrainDrive_OS.LaunchpadFrame1.MainCG1.GroupTransparency = 1
TrainDrive_OS.LaunchpadFrame1.Visible = false

TrainDrive_OS.TDOS_SystemValues.LoadedSystemScriptsValue1.Changed:Connect(function(Value)
	if Value == 3 then
		if TDOS_Module_Script.Save_Settings_DataStore == true then
			if LocalPlayer:FindFirstChild("TDOS_5_DataStoreValues") then
				TDOS_SystemValues.UILanguageValue1.Value = LocalPlayer.TDOS_5_DataStoreValues.UILanguageValue1.Value
				TDOS_SystemValues.HideLaunchpadValue1.Value = LocalPlayer.TDOS_5_DataStoreValues.HideLaunchpadValue1.Value
				TDOS_SystemValues.DashboardDragValue1.Value = LocalPlayer.TDOS_5_DataStoreValues.DashboardDragValue1.Value
				TDOS_SystemValues.LaunchpadDragValue1.Value = LocalPlayer.TDOS_5_DataStoreValues.LaunchpadDragValue1.Value
				TDOS_SystemValues.DashboardPositionValue1.Value = LocalPlayer.TDOS_5_DataStoreValues.DashboardPositionValue1.Value
				TDOS_SystemValues.LaunchpadPositionValue1.Value = LocalPlayer.TDOS_5_DataStoreValues.LaunchpadPositionValue1.Value
				TDOS_SystemValues.LaunchpadButtonLayoutValue1.Value = LocalPlayer.TDOS_5_DataStoreValues.LaunchpadButtonLayoutValue1.Value
			else
				warn("Error! TDOS_5_DataStoreValues Could Not Be Found | NT TDOS 5.0.0 Error Log")
			end
		elseif TDOS_Module_Script.Save_Settings_DataStore == false then
			if TDOS_Module_Script.Auto_Select_Language == true then
				if game:GetService("LocalizationService").RobloxLocaleId == "ja-jp" then
					TrainDrive_OS.TDOS_SystemValues.UILanguageValue1.Value = 2
				end
			end
			
			if TDOS_Module_Script.Start_With_Launchpad_Hidden_On_PC == true then
				TrainDrive_OS.DashboardFrame1.Position = UDim2.fromScale(0.5, TrainDrive_OS.DashboardFrame1.Position.Y.Scale)
				TrainDrive_OS.LaunchpadFrame1.Visible = true
				TrainDrive_OS.TDOS_SystemValues.HideLaunchpadValue1.Value = true
			end
		end
	end
end)

wait(0.5)

TrainDrive_OS.DashboardFrame1.Visible = true
TweenService:Create(TrainDrive_OS.DashboardFrame1, TweenInfo.new(0.5), {BackgroundTransparency = 0}):Play()
TweenService:Create(TrainDrive_OS.DashboardFrame1.MainCG1, TweenInfo.new(0.5), {GroupTransparency = 0}):Play()

TrainDrive_OS.LaunchpadFrame1.Visible = true

if TrainDrive_OS.TDOS_SystemValues.HideLaunchpadValue1.Value == false then
	TweenService:Create(TrainDrive_OS.LaunchpadFrame1, TweenInfo.new(0.5), {BackgroundTransparency = 0}):Play()
	TweenService:Create(TrainDrive_OS.LaunchpadFrame1.MainCG1, TweenInfo.new(0.5), {GroupTransparency = 0}):Play()
end

if TrainDrive_OS:FindFirstChild("EnableDebugLog") then
	print("Initialized TrainDrive OS | NT TDOS 5 Debug Log")
end
]]></ProtectedString>
