				<Item class="ModuleScript" referent="RBX0d5d46fdc8734e79bb99c38a524c0b4a">
					<Properties>
						<Content name="LinkedSource"><null></null></Content>
						<ProtectedString name="Source"><![CDATA[local SystemValues = {}
local TDOS_ModuleScript = require(script.Parent.Parent.TDOS_ModuleScript)
local Train = script.Parent.Parent.TDOS_SystemValues.TrainObjectValue1

if Train.Value == nil then
	Train:GetPropertyChangedSignal("Value"):Wait()
end

if TDOS_ModuleScript.Use_SDN_Version == "3.5" then
	SystemValues.ActualSpeed = Train.Value.State.SpeedStateValue1
	SystemValues.TargetSpeed = Train.Value.State.TargetSpeedValue1
	SystemValues.Direction = Train.Value.State.DirectionValue1
	SystemValues.ControlMethod = Train.Value.State.DriveControlSystemValue1
	SystemValues.MasterControlNotch = Train.Value.State.DriveControlStateValue2
	SystemValues.WASDModeNotch = Train.Value.State.DriveControlStateValue1
	SystemValues.EmergencyBrake = Train.Value.State.EmagencyBrakeValue1
elseif TDOS_ModuleScript.Use_SDN_Version == "4" then	
	SystemValues.ActualSpeed = Train.Value.Values.RealSpeedStateValue1
	SystemValues.TargetSpeed = Train.Value.Values.CurrentSpeedValue1
	SystemValues.Direction = Train.Value.Values.DirectionValue1
	SystemValues.ControlMethod = Train.Value.Values.ControlMethodValue1
	SystemValues.MasterControlNotch = Train.Value.Values.ControlStateValue2
	SystemValues.WASDModeNotch = Train.Value.Values.ControlStateValue1
	SystemValues.EmergencyBrake = Train.Value.Values.EmergencyBrakeValue1
end

return SystemValues
]]></ProtectedString>
