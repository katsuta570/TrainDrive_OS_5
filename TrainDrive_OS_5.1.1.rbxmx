				<Item class="LocalScript" referent="RBX33d319e42faa4d47beb80af7987058fb">
					<Properties>
						<ProtectedString name="Source"><![CDATA[if script.Parent.Parent:FindFirstChild("ApplyAeroTheme") then
	for _, Objects in ipairs(script.Parent.Parent:GetDescendants()) do
		if Objects:IsA("Frame") then
			local FBGGradient = script.Parent.FBGGradient:Clone()
			FBGGradient.Parent = Objects
		elseif Objects:IsA("TextButton") or Objects:IsA("ImageButton") then
			local TBBGGradient = script.Parent.TBBGGradient:Clone()
			TBBGGradient.Parent = Objects
		elseif Objects:IsA("TextLabel") then
			local TextGradient = script.Parent.TextGradient:Clone()
			TextGradient.Parent = Objects
		end
	end
end
]]></ProtectedString>
