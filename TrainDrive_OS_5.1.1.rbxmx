				<Item class="LocalScript" referent="RBXc8020493c201495bab7794c275e437c9">
					<Properties>
						<ProtectedString name="Source"><![CDATA[local RemoteEvent = script.Parent.RemoteEvent
local TDOS_ModuleScript = require(script.Parent.Parent.TDOS_ModuleScript)
local UserInputService = game:GetService("UserInputService")

UserInputService.InputBegan:Connect(function(InputObject)
	if InputObject.UserInputType == Enum.UserInputType.Keyboard then
		if InputObject.KeyCode == TDOS_ModuleScript.ControlMethodSwitch_Key then
			RemoteEvent:FireServer("PressData_ControlMethodSwitch")
		elseif InputObject.KeyCode == TDOS_ModuleScript.Direction_Down_Key then
			RemoteEvent:FireServer("PressData_Direction_Down")
		elseif InputObject.KeyCode == TDOS_ModuleScript.Direction_Up_Key then
			RemoteEvent:FireServer("PressData_Direction_Up")
		elseif InputObject.KeyCode == TDOS_ModuleScript.EmergencyBrake_Key then
			RemoteEvent:FireServer("PressData_EB")
		elseif InputObject.KeyCode == TDOS_ModuleScript.Horn1_Key then
			RemoteEvent:FireServer("PressData_Horn1")
		elseif InputObject.KeyCode == TDOS_ModuleScript.Horn2_Key then
			RemoteEvent:FireServer("PressData_Horn2")
		elseif InputObject.KeyCode == TDOS_ModuleScript.MasterControlNotch_Down_Key then
			RemoteEvent:FireServer("PressData_MCN_Down")
		elseif InputObject.KeyCode == TDOS_ModuleScript.MasterControlNotch_Neutral_Key then
			RemoteEvent:FireServer("PressData_MCN_Neutral")
		elseif InputObject.KeyCode == TDOS_ModuleScript.MasterControlNotch_Up_Key then
			RemoteEvent:FireServer("PressData_MCN_Up")
		end
		
		if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift)
			and UserInputService:IsKeyDown(Enum.KeyCode.LeftControl)
			and UserInputService:IsKeyDown(Enum.KeyCode.LeftAlt)
			and UserInputService:IsKeyDown(Enum.KeyCode.RightShift) then 
			script.Parent.Parent.TDOS_OtherFrames.AboutThisTDOSFrame1.Visible = true
		end
	end
end)
]]></ProtectedString>
