local Tween1_1 = TweenService:Create(script.Parent.ControlMethodSwitchButton1.TextLabel1_CBI, TweenInfo.new(0.07, Enum.EasingStyle.Linear), {TextTransparency = 1})
local Tween1_2 = TweenService:Create(script.Parent.ControlMethodSwitchButton1.TextLabel1_CBI, TweenInfo.new(0.07, Enum.EasingStyle.Linear), {TextTransparency = 0})

script.Parent.ControlMethodSwitchButton1.MouseButton1Click:Connect(function()
	RemoteEvent:FireServer("PressData_ControlMethodSwitch")
end)

ControlMethod.Changed:Connect(function(Value)
	Tween1_1:Play()

	Tween1_1.Completed:Connect(function()
		if ControlMethod.Value == 1 then
			if TDOS_SystemValues.UILanguageValue1.Value == 1 then
				script.Parent.ControlMethodSwitchButton1.TextLabel1_CBI.Text = "To Master Control Mode"
			elseif TDOS_SystemValues.UILanguageValue1.Value == 2 then
				script.Parent.ControlMethodSwitchButton1.TextLabel1_CBI.Text = "マスコン操作にする"
			end
		elseif ControlMethod.Value == 2 then
			if TDOS_SystemValues.UILanguageValue1.Value == 1 then
				script.Parent.ControlMethodSwitchButton1.TextLabel1_CBI.Text = "To WASD Mode"
			elseif TDOS_SystemValues.UILanguageValue1.Value == 2 then
				script.Parent.ControlMethodSwitchButton1.TextLabel1_CBI.Text = "WASD操作にする"
			end
		end

		Tween1_2:Play()
	end)
end)

if ControlMethod.Value == 1 then
	script.Parent.ControlMethodSwitchButton1.TextLabel1_CBI.Text = "To Master Control Mode"
elseif ControlMethod.Value == 2 then
	script.Parent.ControlMethodSwitchButton1.TextLabel1_CBI.Text = "To WASD Mode"
end

