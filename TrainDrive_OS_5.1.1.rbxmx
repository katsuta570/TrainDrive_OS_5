				<Item class="Script" referent="RBXd6523a1313f540c6a7971bfd748d8c65">
					<Properties>
						<ProtectedString name="Source"><![CDATA[local TDOS_ModuleScript = require(script.Parent.Parent.TDOS_ModuleScript)
local Train = script.Parent.Parent.TDOS_SystemValues.TrainObjectValue1

if Train.Value == nil and TDOS_ModuleScript.Auto_Select_Train == true then
	Train.Value = script.Parent.Parent.Parent.Parent
end

if Train.Value == nil and TDOS_ModuleScript.Auto_Select_Train == false then
	warn("Error! No train selected. Auto_Train_Select is disabled. | NT TDOS 5 Debug")
end

local BogieInstancesModuleScript = require(script.Parent.Parent.TDOS_SystemScripts.BogieInstancesModuleScript)
local TDOS_SystemValues = script.Parent.Parent.TDOS_SystemValues
local RemoteEvent = script.Parent.RemoteEvent

local ActualSpeed = BogieInstancesModuleScript.ActualSpeed
local ControlMethod = BogieInstancesModuleScript.ControlMethod
local Direction = BogieInstancesModuleScript.Direction
local EmergencyBrake = BogieInstancesModuleScript.EmergencyBrake
local MasterControlNotch = BogieInstancesModuleScript.MasterControlNotch
local TargetSpeed = BogieInstancesModuleScript.TargetSpeed
local WASDModeNotch = BogieInstancesModuleScript.WASDModeNotch

RemoteEvent.OnServerEvent:Connect(function(Player, Data, Value)
	if Data == "PressData_MCN_Up" then
		if ControlMethod.Value == 2 then
			if MasterControlNotch.Value ~= 8 then
				MasterControlNotch.Value = MasterControlNotch.Value + 1
			end
		end
	elseif Data == "PressData_MCN_Neutral" then
		if ControlMethod.Value == 2 then
			if MasterControlNotch.Value >= 1 then
				MasterControlNotch.Value = MasterControlNotch.Value - 1
			elseif MasterControlNotch.Value <= -1 then
				MasterControlNotch.Value = MasterControlNotch.Value + 1
			end
		end
	elseif Data == "PressData_MCN_Down" then
		if ControlMethod.Value == 2 then
			if MasterControlNotch.Value ~= -5 then
				MasterControlNotch.Value = MasterControlNotch.Value - 1
			end
		end
	elseif Data == "PressData_EB" then
		if ControlMethod.Value == 1 then
			EmergencyBrake.Value = not EmergencyBrake.Value
		elseif ControlMethod.Value == 2 then
			MasterControlNotch.Value = 8
		end
	elseif Data == "PressData_Direction_Up" then
		if TDOS_SystemValues.PlayerSeatValue1.Value == 1 then
			if Direction.Value == 0 then
				Direction.Value = 1
			elseif Direction.Value == -1 then
				Direction.Value = 0
			end
		elseif TDOS_SystemValues.PlayerSeatValue1.Value == 2 then
			if Direction.Value == 0 then
				Direction.Value = -1
			elseif Direction.Value == 1 then
				Direction.Value = 0
			end
		end
	elseif Data == "PressData_Direction_Down" then
		if TDOS_SystemValues.PlayerSeatValue1.Value == 1 then
			if Direction.Value == 0 then
				Direction.Value = -1
			elseif Direction.Value == 1 then
				Direction.Value = 0
			end
		elseif TDOS_SystemValues.PlayerSeatValue1.Value == 2 then
			if Direction.Value == 0 then
				Direction.Value = 1
			elseif Direction.Value == -1 then
				Direction.Value = 0
			end
		end
	elseif Data == "PressData_Horn1" then
		if TDOS_SystemValues.PlayerSeatValue1.Value == 1 then
			Train.Value.VehicleSeat1.HornSound1:Play()
		elseif TDOS_SystemValues.PlayerSeatValue1.Value == 2 then
			Train.Value.VehicleSeat2.HornSound1:Play()
		end
	elseif Data == "PressData_Horn2" then
		if TDOS_SystemValues.PlayerSeatValue1.Value == 1 then
			Train.Value.VehicleSeat1.HornSound2:Play()
		elseif TDOS_SystemValues.PlayerSeatValue1.Value == 2 then
			Train.Value.VehicleSeat2.HornSound2:Play()
		end
	elseif Data == "PressData_ControlMethodSwitch" then
		if TargetSpeed.Value <= 2 then
			if ControlMethod.Value == 1 then
				ControlMethod.Value = 2
				EmergencyBrake.Value = false
			elseif ControlMethod.Value == 2 then
				ControlMethod.Value = 1
				MasterControlNotch.Value = 0
			end
		end
	elseif Data == "DeleteTrainData1" then
		local StopScripts = {}
		local DeletedInstances = {}
		
		Train.Value:Destroy()
		
		if script.Parent.Parent:FindFirstChild("EnableDebugLog") then
			print("Execute safe removal of TrainDrive OS | NT TrainDrive OS 5.0.0, Debug")
		end
			
		for _, Instances in ipairs(script.Parent.Parent:GetDescendants()) do
			if (Instances:IsA("Script") or Instances:IsA("LocalScript")) and Instances ~= script then
				table.insert(StopScripts, Instances)
				Instances.Enabled = false
			end
		end
		
		for _, Instances in ipairs(script.Parent.Parent:GetDescendants()) do
			if Instances ~= script and Instances ~= script.Parent and Instances.Name ~= "EnableDebugLog" then
				table.insert(DeletedInstances, Instances)
				Instances:Destroy()
			end
		end
		
		if script.Parent.Parent:FindFirstChild("EnableDebugLog") then
			print(StopScripts)
			print(DeletedInstances)
		end
		
		script.Parent.Parent:Destroy()
	end
	
	if TDOS_ModuleScript.Save_Settings_DataStore == true then
		if Player:FindFirstChild("TDOS_5_DataStoreValues") then
			RemoteEvent.OnServerEvent:Connect(function(Player, Data, Value)
				if Data == "UDSData_UILanguageValue1" then
					Player.TDOS_5_DataStoreValues.UILanguageValue1.Value = Value
				elseif Data == "UDSData_DashboardPositionValue1" then
					Player.TDOS_5_DataStoreValues.DashboardPositionValue1.Value = Value
				elseif Data == "UDSData_LaunchpadPositionValue1" then
					Player.TDOS_5_DataStoreValues.LaunchpadPositionValue1.Value = Value
				elseif Data == "UDSData_DashboardDragValue1" then
					Player.TDOS_5_DataStoreValues.DashboardDragValue1.Value = Value
				elseif Data == "UDSData_LaunchpadDragValue1" then
					Player.TDOS_5_DataStoreValues.LaunchpadDragValue1.Value = Value
				elseif Data == "UDSData_LaunchpadButtonLayoutValue1" then
					Player.TDOS_5_DataStoreValues.LaunchpadButtonLayoutValue1.Value = Value
				elseif Data == "UDSData_HideLaunchpadValue1" then
					Player.TDOS_5_DataStoreValues.HideLaunchpadValue1.Value = Value
				end
			end)
		else
			warn("Error! Save_Settings_DataStore is enabled, but TDOS_5_DataStoreValues could not be found.")
		end
	end
end)
]]></ProtectedString>
