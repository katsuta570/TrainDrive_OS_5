					<Properties>
						<ProtectedString name="Source"><![CDATA[local BogieInstancesModuleScript = require(script.Parent.Parent.TDOS_SystemScripts.BogieInstancesModuleScript)
local DashboardFrame1 = script.Parent.Parent.DashboardFrame1.MainCG1
