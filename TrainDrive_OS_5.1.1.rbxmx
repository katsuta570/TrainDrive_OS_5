TDOS_SystemValues.HideLaunchpadValue1.Changed:Connect(function(Value)
	local Tween5_1 = TweenService:Create(script.Parent.Parent, TweenInfo.new(0.7, Enum.EasingStyle.Exponential), {Position = UDim2.fromScale(0.68, script.Parent.Parent.Position.Y.Scale)})
	local Tween5_2 = TweenService:Create(script.Parent.Parent, TweenInfo.new(0.7, Enum.EasingStyle.Exponential), {Position = UDim2.fromScale(0.75, script.Parent.Parent.Position.Y.Scale)})
	
	if TDOS_SystemValues.DashboardDragValue1.Value == false then
		if Value == false then
			Tween5_1:Play()
		elseif Value == true then
			Tween5_2:Play()
		end
	end
end)

